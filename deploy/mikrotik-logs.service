[Unit]
Description=MikroTik UDP Syslog Collector
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
ExecStart=/usr/bin/python3 /root/mikrotik-logs/app.py --bind 0.0.0.0 --port 514 --db-path /root/mikrotik-logs/data/logs.db
Restart=always
RestartSec=2
User=root
WorkingDirectory=/root/mikrotik-logs

[Install]
WantedBy=multi-user.target
